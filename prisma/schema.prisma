generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model certifications {
  id         String    @id @db.Uuid
  title      String    @db.VarChar(255)
  issuer     String    @db.VarChar(255)
  date       DateTime? @db.Date
  url        String    @db.VarChar(255)
  image_url  String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project_technologies {
  project_id    String       @db.Uuid
  technology_id String       @db.Uuid
  projects      projects     @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  technologies  technologies @relation(fields: [technology_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([project_id, technology_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projects {
  id                   String                 @id @db.Uuid
  title                String                 @db.VarChar(255)
  description          String?
  status               project_status?        @default(draft)
  image_url            String?                @db.VarChar(255)
  github               String?                @db.VarChar(255)
  demo_url             String?                @db.VarChar(255)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  project_technologies project_technologies[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model skills {
  id                 String               @id @db.Uuid
  category           String               @db.VarChar(255)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  skill_technologies skill_technologies[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model socials {
  id         String    @id @db.Uuid
  platform   String    @db.VarChar(255)
  icon_url   String?   @db.VarChar(255)
  url        String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model educations {
  id         String    @id @db.Uuid
  degree     String    @db.VarChar(100)
  school     String    @db.VarChar(255)
  started_at DateTime  @db.Date
  ended_at   DateTime? @db.Date
  details    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model experiences {
  id         String    @id @db.Uuid
  role       String?   @db.VarChar(100)
  company    String    @db.VarChar(255)
  started_at DateTime  @db.Date
  ended_at   DateTime? @db.Date
  details    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model profiles {
  id            String    @id @db.Uuid
  name          String    @db.VarChar(255)
  title         String?   @db.VarChar(255)
  bio           String?
  resume_url    String?   @db.VarChar(255)
  contact_email String?   @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model skill_technologies {
  skill_id      String       @db.Uuid
  technology_id String       @db.Uuid
  skills        skills       @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  technologies  technologies @relation(fields: [technology_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([skill_id, technology_id])
}

model technologies {
  id                   String                 @id @db.Uuid
  tech                 String                 @unique @db.VarChar(255)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  icon_url             String?                @db.VarChar(255)
  project_technologies project_technologies[]
  skill_technologies   skill_technologies[]
}

enum project_status {
  draft
  in_progress
  completed
  archived
}
